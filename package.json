{
  "name": "athena-usage-tracker",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "widget": "powershell -ExecutionPolicy Bypass -File ./scripts/open-widget.ps1",
    "widget:win": "powershell -ExecutionPolicy Bypass -File ./scripts/open-widget.ps1",
    "widget:win:interactive": "powershell -ExecutionPolicy Bypass -File ./scripts/open-widget.ps1 -ClickThrough 0"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  },
  "dependencies": {
    "web-push": "^3.6.7"
  }
}
