# Copy to .env or ~/.config/athena-usage-tracker/env and fill in local secrets.
# .env and .env.local are ignored by git. The user-level file is shared by all worktrees.

# Optional server settings
PORT=8080
HOST=127.0.0.1

# OpenRouter account keys referenced from data/accounts.json
OPENROUTER_API_KEY_PERSONAL=sk-or-your-key-here
